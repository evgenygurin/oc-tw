{{ header }}

{# Hero Section inspired by Astro Ecommerce PromoSectionLarge #}
<section class="hero-section bg-gradient-primary text-white py-5 mb-5">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-lg-6 mb-4 mb-lg-0">
        <h1 class="display-4 fw-bold mb-3">{{ heading_title }}</h1>
        <p class="lead mb-4">Discover amazing products at unbeatable prices. Shop now and enjoy exclusive deals!</p>
        <a href="{{ category }}" class="btn btn-light btn-lg px-5">Shop Now</a>
      </div>
      <div class="col-lg-6 text-center">
        <img src="catalog/view/theme/oc-astro/image/hero-product.png" alt="Featured Products" class="img-fluid" style="max-height: 400px;" />
      </div>
    </div>
  </div>
</section>

{# Incentives Section - like incentiveCols component #}
<section class="incentives-section py-4 bg-light">
  <div class="container">
    <div class="row text-center">
      <div class="col-md-4 mb-4 mb-md-0">
        <div class="incentive-item">
          <i class="fas fa-shipping-fast fa-3x text-primary mb-3"></i>
          <h5 class="fw-bold">Free Shipping</h5>
          <p class="text-muted small">On orders over $50</p>
        </div>
      </div>
      <div class="col-md-4 mb-4 mb-md-0">
        <div class="incentive-item">
          <i class="fas fa-undo-alt fa-3x text-primary mb-3"></i>
          <h5 class="fw-bold">Easy Returns</h5>
          <p class="text-muted small">30-day return policy</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="incentive-item">
          <i class="fas fa-lock fa-3x text-primary mb-3"></i>
          <h5 class="fw-bold">Secure Checkout</h5>
          <p class="text-muted small">SSL encrypted payments</p>
        </div>
      </div>
    </div>
  </div>
</section>

{# Featured Products Section - CardProduct grid #}
<section class="featured-products py-5">
  <div class="container">
    <div class="section-header text-center mb-5">
      <h2 class="fw-bold">Featured Products</h2>
      <p class="text-muted">Check out our best sellers and trending items</p>
    </div>

    <div class="row">
      {% for product in products %}
      <div class="col-md-6 col-lg-3 mb-4">
        <div class="card card-product border shadow-sm border-radius-lg h-100">
          <a href="{{ product.href }}">
            <div class="product-image-wrapper" style="height: 300px; overflow: hidden;">
              <img class="card-img-top p-4" src="{{ product.thumb }}" alt="{{ product.name }}" style="width: 100%; height: 100%; object-fit: contain;" />
            </div>
            <div class="card-body text-center">
              <h6 class="card-title fw-bold mb-2">{{ product.name }}</h6>
              {% if product.price %}
              <p class="text-muted small mb-2">{{ product.description|slice(0, 60) }}...</p>
              <div class="price-wrapper">
                {% if product.special %}
                <h5 class="text-danger mb-0">${{ product.special }}</h5>
                <small class="text-muted text-decoration-line-through">${{ product.price }}</small>
                {% else %}
                <h5 class="mb-0">${{ product.price }}</h5>
                {% endif %}
              </div>
              {% endif %}
              <button class="btn btn-primary btn-sm mt-3" onclick="cart.add('{{ product.product_id }}');">
                <i class="fas fa-shopping-cart me-2"></i>Add to Cart
              </button>
            </div>
          </a>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

{# Categories Section - CardCategory grid #}
{% if categories %}
<section class="categories-section py-5 bg-light">
  <div class="container">
    <div class="section-header text-center mb-5">
      <h2 class="fw-bold">Shop by Category</h2>
      <p class="text-muted">Browse our wide range of product categories</p>
    </div>

    <div class="row">
      {% for category in categories %}
      <div class="col-md-6 col-lg-4 mb-4">
        <a href="{{ category.href }}" class="text-decoration-none">
          <div class="card card-category border-0 shadow-sm hover-shadow h-100">
            <img class="card-img-top" src="{{ category.thumb }}" alt="{{ category.name }}" style="height: 200px; object-fit: cover;" />
            <div class="card-body text-center">
              <h5 class="card-title fw-bold text-dark">{{ category.name }}</h5>
              <p class="text-muted small">Explore Collection <i class="fas fa-arrow-right ms-2"></i></p>
            </div>
          </div>
        </a>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

{# Promo Banner Section #}
<section class="promo-banner py-5">
  <div class="container">
    <div class="row align-items-center bg-primary text-white rounded-3 p-5">
      <div class="col-lg-8">
        <h3 class="fw-bold mb-3">Subscribe to our Newsletter</h3>
        <p class="mb-0">Get exclusive deals, product updates, and special offers delivered to your inbox.</p>
      </div>
      <div class="col-lg-4 text-lg-end mt-3 mt-lg-0">
        <button class="btn btn-light btn-lg px-5">Subscribe Now</button>
      </div>
    </div>
  </div>
</section>

{{ content_bottom }}
{{ footer }}

