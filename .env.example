# MariaDB Configuration
MARIADB_ROOT_PASSWORD=your_secure_root_password
MARIADB_DATABASE=opencart_db
MARIADB_USER=opencart
MARIADB_PASSWORD=your_secure_password

# OpenCart Configuration
OPENCART_ADMIN_USERNAME=admin
OPENCART_ADMIN_PASSWORD=admin123
OPENCART_ADMIN_EMAIL=admin@example.com

# Timezone
TZ=UTC

# Sentry Error Tracking (via MCP Server)
# Get these values from https://sentry.io
SENTRY_DSN=https://YOUR_PUBLIC_KEY@o0.ingest.sentry.io/PROJECT_ID
SENTRY_ORGANIZATION=your-organization-slug
SENTRY_PROJECT=your-project-slug
SENTRY_AUTH_TOKEN=sntrys_YOUR_AUTH_TOKEN_HERE
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=1.0
