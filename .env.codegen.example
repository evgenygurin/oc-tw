# =================================================================
# Codegen Agent Environment Configuration
# =================================================================
# This file contains environment variables for the Codegen AI agent
# and its MCP (Model Context Protocol) servers.
#
# SETUP INSTRUCTIONS:
# 1. Copy this file: cp .env.codegen.example .env.codegen
# 2. Fill in your actual API keys (never commit .env.codegen!)
# 3. Restart Codegen orchestrator if already running
#
# SECURITY: .env.codegen is in .gitignore - never commit it!
# =================================================================

# --- MCP Server: Exa (Web Search & Research) ---
# Get your API key from: https://exa.ai/
# Used for intelligent web search and content retrieval
EXA_API_KEY=your_exa_api_key_here

# --- MCP Server: Tavily (Advanced Research) ---
# Get your API key from: https://tavily.com/
# Used for deep research and information gathering
TAVILY_API_KEY=your_tavily_api_key_here

# --- MCP Server: Context7 (Optional) ---
# If using Context7 MCP server for contextual memory, add credentials here
# Check with your team if this is required for your workflow
# CONTEXT7_API_KEY=your_context7_key_here
# CONTEXT7_ENDPOINT=https://api.context7.example.com

# --- Sentry Integration (Optional) ---
# For error tracking and monitoring in Codegen agent operations
# Get DSN from: https://sentry.io/
# Note: This is for Codegen operations, not OpenCart application
# SENTRY_DSN=https://[key]@[org].ingest.sentry.io/[project]
# SENTRY_ENVIRONMENT=development
# SENTRY_TRACES_SAMPLE_RATE=1.0

# --- Memory MCP Server (Optional) ---
# For persistent agent memory across sessions
# MEMORY_STORAGE_PATH=/tmp/codegen-memory
# MEMORY_BACKEND=sqlite

# =================================================================
# Codegen Orchestrator Settings
# (These may be configured via docker-setup.sh or admin panel)
# =================================================================

# CircleCI Project Configuration
# Format: gh/username/repository
# CODEGEN_CIRCLECI_PROJECT_SLUG=gh/username/repository

# ClickUp Configuration  
# CODEGEN_CLICKUP_LIST_ID=your_clickup_list_id_here

# Team Assignments (ClickUp User IDs)
# CODEGEN_DEV_TEAM_LEAD=dev_team_lead_user_id
# CODEGEN_DEVOPS_LEAD=devops_lead_user_id  
# CODEGEN_QA_LEAD=qa_lead_user_id

# Monitoring Configuration
# CODEGEN_MONITOR_INTERVAL=300  # 5 minutes
# CODEGEN_AUTO_FIX_ENABLED=true

# Webhook Configuration (optional)
# CODEGEN_WEBHOOK_URL=https://yourdomain.com/codegen_integration/webhook_endpoint.php

# =================================================================
# Usage Notes:
# - All MCP API keys should be kept secure and never committed to git
# - .env.codegen is automatically ignored by .gitignore
# - Restart services after updating: docker compose restart opencart
# - Test MCP connectivity via admin panel: Extensions > Codegen Orchestrator
# =================================================================

