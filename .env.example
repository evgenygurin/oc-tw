# =================================================================
# OpenCart & Docker Environment Configuration
# =================================================================
# This file contains environment variables for the OpenCart application
# and Docker services. For Codegen/MCP server configuration, see:
# .env.codegen.example
# =================================================================

# MariaDB Configuration
MARIADB_ROOT_PASSWORD=your_secure_root_password
MARIADB_DATABASE=opencart_db
MARIADB_USER=opencart
MARIADB_PASSWORD=your_secure_password

# OpenCart Configuration
OPENCART_ADMIN_USERNAME=admin
OPENCART_ADMIN_PASSWORD=admin123
OPENCART_ADMIN_EMAIL=admin@example.com

# Timezone
TZ=UTC

# Sentry Configuration (optional - for OpenCart application monitoring)
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0

# =================================================================
# Note: For Codegen AI agent and MCP servers (Exa, Tavily, etc.),
# use .env.codegen instead. Copy .env.codegen.example to .env.codegen
# and add your API keys there (never commit .env.codegen to git).
# =================================================================
